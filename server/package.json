{
    "name": "iso27001-audit-api",
    "version": "1.0.0",
    "description": "API Backend for ISO 27001 Audit App",
    "main": "src/index.js",
    "type": "module",
    "scripts": {
        "build": "npx prisma generate && npx prisma migrate deploy",
        "start": "node src/index.js",
        "dev": "node --watch src/index.js",
        "prisma:generate": "npx prisma generate",
        "prisma:migrate": "npx prisma migrate dev",
        "prisma:seed": "node prisma/seed.js",
        "prisma:studio": "npx prisma studio",
        "setup": "npx prisma migrate dev --name init && node prisma/seed.js"
    },
    "prisma": {
        "seed": "node prisma/seed.js"
    },
    "dependencies": {
        "@prisma/client": "^6.4.1",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^8.4.1",
        "express-validator": "^7.0.1",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^8.0.5",
        "resend": "^6.12.2"
    },
    "devDependencies": {
        "prisma": "^6.4.1"
    }
}
