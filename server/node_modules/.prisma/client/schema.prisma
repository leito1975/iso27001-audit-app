// AuditIA - Multi-Audit Management Platform (formerly ISO 27001 Audit Pro)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Audit {
  id           Int      @id @default(autoincrement())
  name         String
  norm         String   @default("iso27001")
  status       String   @default("draft")
  organization String?
  auditor      String?
  startDate    String?  @map("start_date")
  endDate      String?  @map("end_date")
  scope        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  findings    Finding[]
  risks       Risk[]
  assessments ControlAssessment[]

  @@map("audits")
}

model User {
  id           Int                 @id @default(autoincrement())
  email        String              @unique
  passwordHash String?             @map("password_hash")
  name         String
  role         String              @default("auditor")
  status       String              @default("active")
  inviteToken  String?             @map("invite_token")
  inviteExpiry DateTime?           @map("invite_expiry")
  createdAt    DateTime            @default(now()) @map("created_at")
  assessments  ControlAssessment[]
  findings     Finding[]

  @@map("users")
}

model Control {
  id          String              @id
  name        String
  description String?
  category    String?
  objective   String?
  assessments ControlAssessment[]
  findings    FindingControl[]
  risks       RiskControl[]
  attachments Attachment[]

  @@map("controls")
}

model ControlAssessment {
  id            Int      @id @default(autoincrement())
  controlId     String   @map("control_id")
  auditId       Int?     @map("audit_id")
  maturityLevel Int?     @map("maturity_level")
  targetLevel   Int      @default(3) @map("target_level")
  applicable    Boolean  @default(true)
  evidence      String?
  assessedBy    Int?     @map("assessed_by")
  assessedAt    DateTime @default(now()) @map("assessed_at")

  control  Control @relation(fields: [controlId], references: [id], onDelete: Cascade)
  audit    Audit?  @relation(fields: [auditId], references: [id], onDelete: Cascade)
  assessor User?   @relation(fields: [assessedBy], references: [id])

  @@unique([controlId, auditId])
  @@map("control_assessments")
}

model Tag {
  id       Int          @id @default(autoincrement())
  name     String
  color    String       @default("#3b82f6")
  findings FindingTag[]
  risks    RiskTag[]

  @@map("tags")
}

model Finding {
  id             Int      @id @default(autoincrement())
  title          String
  description    String?
  type           String?
  status         String   @default("open")
  severity       String?
  evidence       String?
  recommendation String?
  auditId        Int?     @map("audit_id")
  createdBy      Int?     @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  audit       Audit?           @relation(fields: [auditId], references: [id], onDelete: Cascade)
  creator     User?            @relation(fields: [createdBy], references: [id])
  controls    FindingControl[]
  tags        FindingTag[]
  actionPlans ActionPlan[]

  @@map("findings")
}

// Many-to-many: Finding <-> Control
model FindingControl {
  findingId Int    @map("finding_id")
  controlId String @map("control_id")

  finding Finding @relation(fields: [findingId], references: [id], onDelete: Cascade)
  control Control @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@id([findingId, controlId])
  @@map("finding_controls")
}

model FindingTag {
  findingId Int @map("finding_id")
  tagId     Int @map("tag_id")

  finding Finding @relation(fields: [findingId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([findingId, tagId])
  @@map("finding_tags")
}

model Risk {
  id                  Int       @id @default(autoincrement())
  name                String
  description         String?
  category            String?
  probability         Int?
  impact              Int?
  status              String    @default("identificado")
  treatment           String?
  treatmentPlan       String?   @map("treatment_plan")
  owner               String?
  targetDate          DateTime? @map("target_date")
  residualProbability Int?      @map("residual_probability")
  residualImpact      Int?      @map("residual_impact")
  residualNotes       String?   @map("residual_notes")
  residualEvaluatedAt DateTime? @map("residual_evaluated_at")
  auditId             Int?      @map("audit_id")
  createdAt           DateTime  @default(now()) @map("created_at")

  audit       Audit?        @relation(fields: [auditId], references: [id], onDelete: Cascade)
  controls    RiskControl[]
  tags        RiskTag[]
  actionPlans ActionPlan[]

  @@map("risks")
}

// Many-to-many: Risk <-> Control
model RiskControl {
  riskId    Int    @map("risk_id")
  controlId String @map("control_id")

  risk    Risk    @relation(fields: [riskId], references: [id], onDelete: Cascade)
  control Control @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@id([riskId, controlId])
  @@map("risk_controls")
}

model RiskTag {
  riskId Int @map("risk_id")
  tagId  Int @map("tag_id")

  risk Risk @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([riskId, tagId])
  @@map("risk_tags")
}

model ActionPlan {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  findingId   Int?      @map("finding_id")
  riskId      Int?      @map("risk_id")
  responsible String?
  dueDate     DateTime? @map("due_date")
  status      String    @default("pendiente")
  createdAt   DateTime  @default(now()) @map("created_at")

  finding Finding? @relation(fields: [findingId], references: [id])
  risk    Risk?    @relation(fields: [riskId], references: [id])

  @@map("action_plans")
}

model Attachment {
  id         Int      @id @default(autoincrement())
  filename   String?
  filePath   String?  @map("file_path")
  fileType   String?  @map("file_type")
  fileSize   Int?     @map("file_size")
  controlId  String?  @map("control_id")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  control Control? @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@map("attachments")
}
